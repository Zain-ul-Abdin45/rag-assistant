  "themeVariables": {
    "primaryColor": "#1e293b",
    "primaryTextColor": "#f1f5f9",
    "primaryBorderColor": "#334155",
    "lineColor": "#64748b",
    "secondaryColor": "#0f172a",
    "tertiaryColor": "#1e293b",
    "background": "#0f172a",
    "mainBkg": "#1e293b",
    "nodeBorder": "#334155",
    "clusterBkg": "#1e293b",
