flowchart TD

    %% ── Style Classes ────────────────────────────────────────────────────────
    classDef browser  fill:#1e3a5f,color:#93c5fd,stroke:#3b82f6,stroke-width:2px
    classDef api      fill:#1a3a2a,color:#86efac,stroke:#22c55e,stroke-width:2px
    classDef process  fill:#2a1a3a,color:#c4b5fd,stroke:#8b5cf6,stroke-width:2px
    classDef storage  fill:#3a2a00,color:#fcd34d,stroke:#f59e0b,stroke-width:2px
    classDef llm      fill:#3a1a2a,color:#f9a8d4,stroke:#ec4899,stroke-width:2px
    classDef future   fill:#1a1a2a,color:#94a3b8,stroke:#475569,stroke-width:1px,stroke-dasharray:5 4
    classDef config   fill:#1a2a3a,color:#7dd3fc,stroke:#0ea5e9,stroke-width:1px

    %% ════════════════════════════════════════════════════════════════════════
    %% LAYER 0 — BROWSER / CLIENT
    %% ════════════════════════════════════════════════════════════════════════

    subgraph CLIENT["  Browser — static/index.html  "]
        direction LR
        UI_UP["Upload PDF\ndrag-drop or file picker"]:::browser
        UI_CHAT["Chat Interface\nmessage input · history · streaming tokens"]:::browser
        UI_DOCS["Document Sidebar\nlist · delete · Summary button"]:::browser
        UI_SRC["Sources Panel\ngrouped by file · excerpt count badge"]:::browser
        UI_MOD["Summary Modal\nMarkdown render · Download .md"]:::browser
        UI_SID["session_id\ncrypto.randomUUID()\nstored in localStorage"]:::browser
    end

    %% ════════════════════════════════════════════════════════════════════════
    %% LAYER 1 — FASTAPI APPLICATION
    %% ════════════════════════════════════════════════════════════════════════

    subgraph FASTAPI["  FastAPI — main.py  "]
        direction LR
        EP_UP["POST /documents\naccept PDF · save to uploads/\nstart background job"]:::api
        EP_JOBS["GET /jobs/{id}\npoll ingest status · phase · progress"]:::api
        EP_LIST["GET /documents\nlist all docs with metadata"]:::api
        EP_SUM["GET /documents/{id}/summary\nread summaries/*.md · return Markdown"]:::api
        EP_DEL["DELETE /documents/{id}\ncascade delete chunks + vectors + file"]:::api
        EP_CHAT["POST /chat\nStreamingResponse NDJSON"]:::api
        EP_HEALTH["GET /health\nOllama ping · model check"]:::api
    end

    %% ════════════════════════════════════════════════════════════════════════
    %% LAYER 2 — STARTUP SAFETY CHECKS
    %% ════════════════════════════════════════════════════════════════════════

    subgraph STARTUP["  Startup Safety Checks — lifespan()  "]
        direction LR
        ST1["Dimension guard\nSELECT array_length(embedding,1) FROM vec_chunks LIMIT 1\nif stored dim != EMBED_DIM → RuntimeError on startup"]:::api
        ST2["Orphan cleanup\nDELETE FROM documents WHERE id NOT IN\n  (SELECT doc_id FROM chunks)\nlogged as WARNING per removed file"]:::api
    end

    %% ════════════════════════════════════════════════════════════════════════
    %% LAYER 3 — INGESTION PIPELINE
    %% ════════════════════════════════════════════════════════════════════════

    subgraph INGEST["  Ingestion Pipeline — ingest.py  "]
        direction TB

        subgraph EXT["Phase 1 — Extract"]
            direction LR
            I1["extract_text()\nPyMuPDF · page-by-page text join\nwarns if less than 500 chars (scanned PDF)"]:::process
        end

        subgraph CHUNK["Phase 2 — Recursive Chunk"]
            direction LR
            I2A["Split on blank lines\n→ paragraph segments"]:::process
            I2B["Paragraph exceeds CHUNK_SIZE?\n→ re.split on .!? sentence boundaries"]:::process
            I2C["Sentence still too long?\n→ hard character split\nwith CHUNK_OVERLAP carry-over"]:::process
            I2A --> I2B --> I2C
        end

        subgraph EMB["Phase 3 — Parallel Embed"]
            direction LR
            I3["_embed_all()\nThreadPoolExecutor — EMBED_WORKERS threads\ncalls get_embedding() per chunk via Ollama\non_progress callback → job status update"]:::process
        end

        subgraph WRIT["Phase 4 — Write to DB"]
            direction LR
            I4["INSERT INTO documents\nINSERT INTO chunks  (chunk_text, chunk_index)\nINSERT INTO vec_chunks  (Vector embedding)"]:::process
        end

        EXT --> CHUNK --> EMB --> WRIT
    end

    subgraph SUMMARIZE["  Summarization — summarize.py  "]
        direction LR
        S1["Collect all chunk text for document"]:::process
        S2["Prompt llama3.2\nSections: Overview · Key Topics\nMain Findings · Methodology · Conclusions"]:::process
        S3["Save summaries/summary_{stem}_{YYYYMMDD}.md"]:::process
        S1 --> S2 --> S3
    end

    %% ════════════════════════════════════════════════════════════════════════
    %% LAYER 4 — RAG PIPELINE
    %% ════════════════════════════════════════════════════════════════════════

    subgraph RAG["  RAG Pipeline — rag.py  "]
        direction TB

        subgraph MEMR["Step 1 — Memory Recall"]
            direction LR
            R1["recall_memory(query)\nembed query → scan vec_conversations\ncosine distance less than 0.5 → include\nreturn top 3 past Q+A pairs as context"]:::process
        end

        subgraph HYBS["Step 2 — Hybrid Search"]
            direction LR
            R2A["embed query\nnomic-embed-text via Ollama"]:::process
            R2B["pgvector cosine scan\nSELECT TOP_K x 4 candidates\nordered by embedding <=> query_vec\noperator: cosine distance (0 to 2)"]:::process
            R2C["BM25 keyword scoring\nBM25Okapi over candidate pool\nranked by term frequency"]:::process
            R2D["RRF Fusion\nfor each signal: score += 1/(60+rank+1)\ncombine pgvector rank + BM25 rank\nfused order = best of both signals"]:::process
            R2E["Cosine threshold filter\ndrop chunks with distance >= 0.7\nkeep top TOP_K chunks\nif zero pass: return off-topic message"]:::process
            R2A --> R2B --> R2D
            R2A --> R2C --> R2D
            R2D --> R2E
        end

        subgraph RRNK["Step 3 — Rerank"]
            direction LR
            R3["Lost-in-the-middle mitigation\nposition 0  → best chunk  (LLM reads first)\nposition -1 → 2nd best chunk  (LLM reads last)\npositions 1..n-2 → remaining chunks\nLLMs under-attend to middle positions"]:::process
        end

        subgraph PROM["Step 4 — Prompt Assembly"]
            direction LR
            R4["build_messages()\nSystem block:\n  [Source: filename] chunk_text per source\n  past Q+A memory if recalled\nHistory: prior messages in this tab\nUser: current question"]:::process
        end

        subgraph STRM["Step 5 — Stream Response"]
            direction LR
            R5A["yield sources NDJSON\n{type: sources, data: [...]}"]:::process
            R5B["client.chat(stream=True)\nllama3.2 token-by-token"]:::process
            R5C["yield token NDJSON\n{type: token, data: ...}"]:::process
            R5D["yield done NDJSON\n{type: done}"]:::process
            R5E["save_turn()\nINSERT Q+A → conversations\nembed question → vec_conversations\nfor future memory recall"]:::process
            R5A --> R5B --> R5C --> R5D --> R5E
        end

        MEMR --> HYBS --> RRNK --> PROM --> STRM
    end

    %% ════════════════════════════════════════════════════════════════════════
    %% LAYER 5 — DATA STORES
    %% ════════════════════════════════════════════════════════════════════════

    subgraph PG["  PostgreSQL + pgvector (docker: postgres)  "]
        direction LR
        DB1["documents\nid · filename · filepath · pages · created_at"]:::storage
        DB2["chunks\nid · doc_id · chunk_text · chunk_index"]:::storage
        DB3["vec_chunks\nchunk_id · embedding vector(768)\ncosine distance operator: <=>"]:::storage
        DB4["conversations\nid · session_id · turn_id · role · content · created_at\nturn_id links user row to assistant reply"]:::storage
        DB5["vec_conversations\nconversation_id (user rows only) · embedding vector(768)\nused for semantic memory recall"]:::storage
    end

    subgraph DISK["  Filesystem  "]
        direction LR
        D1["uploads/\noriginal PDF files"]:::storage
        D2["summaries/\nsummary_{name}_{date}.md"]:::storage
        D3["logs/\nrotating app log files"]:::storage
    end

    %% ════════════════════════════════════════════════════════════════════════
    %% LAYER 6 — OLLAMA / INFERENCE
    %% ════════════════════════════════════════════════════════════════════════

    subgraph OLLAMA["  Ollama — Local LLM Server (docker: ollama)  "]
        direction LR
        OL1["nomic-embed-text\n768-dim dense vectors\nused for: PDF chunks · queries · memory Q+A"]:::llm
        OL2["llama3.2\nstreaming chat inference\nused for: answers · document summarization"]:::llm
    end

    %% ════════════════════════════════════════════════════════════════════════
    %% LAYER 7 — CROSS-CUTTING
    %% ════════════════════════════════════════════════════════════════════════

    subgraph XCUT["  Cross-cutting Modules  "]
        direction LR
        CFG["config.py\nloads env.local via python-dotenv\nsingle source of truth for all settings\nEMBED_DIM · TOP_K · CHUNK_SIZE etc."]:::config
        DBI["db.py\npsycopg[binary] + pgvector\ninit_db() — CREATE TABLE IF NOT EXISTS\nget_db() — Row-dict cursor connection"]:::config
        LOG["logger.py\nRotatingFileHandler + StreamHandler\nget_logger(__name__) per module\nLOG_LEVEL from env.local"]:::config
    end

    %% ════════════════════════════════════════════════════════════════════════
    %% PLANNED EXTENSIONS
    %% ════════════════════════════════════════════════════════════════════════

    subgraph FUTURE["  Planned Extensions (not yet implemented)  "]
        direction LR
        F1["P6 — Table extraction\nfitz.find_tables() → pandas → Markdown\npreserves tabular data in chunks"]:::future
        F2["P7 — JWT Auth\npython-jose · passlib\nprotect all routes · user registration"]:::future
        F3["P8 — Per-user isolation\nuser_id on documents + conversations\nPostgreSQL row-level security"]:::future
        F4["P9 — RQ job queue\nRedis + RQ workers\nreplace FastAPI BackgroundTasks"]:::future
        F5["Phase 1 — LlamaIndex\nOllamaEmbedding · PGVectorStore\nContextChatEngine · ChatMemoryBuffer"]:::future
        F6["Phase 2 — LangGraph\nstate graph orchestration\nparallel ingest branches\nconditional retrieval routing"]:::future
    end

    %% ════════════════════════════════════════════════════════════════════════
    %% EDGES
    %% ════════════════════════════════════════════════════════════════════════

    %% Client → API
    UI_UP -->|"POST /documents\nmultipart PDF"| EP_UP
    UI_CHAT -->|"POST /chat\nmessage + history + session_id"| EP_CHAT
    UI_DOCS -->|"GET /documents"| EP_LIST
    UI_DOCS -->|"DELETE /documents/{id}"| EP_DEL
    UI_MOD -->|"GET /documents/{id}/summary"| EP_SUM
    UI_DOCS -.->|"GET /jobs/{id}\npoll during upload"| EP_JOBS

    %% Startup
    STARTUP -.->|"runs before first request"| PG

    %% Upload pipeline
    EP_UP -->|"BackgroundTask: _run_ingest()"| INGEST
    INGEST -->|"phase 2: generate summary"| SUMMARIZE
    INGEST -->|"write rows"| DB1
    INGEST -->|"write rows"| DB2
    INGEST -->|"write vectors"| DB3
    INGEST -->|"save original"| D1
    SUMMARIZE -->|"save Markdown"| D2

    %% Embed calls during ingest
    INGEST -->|"embed each chunk\n_embed_all() via ThreadPool"| OL1
    SUMMARIZE -->|"generate summary text"| OL2

    %% Chat pipeline
    EP_CHAT -->|"stream_chat()"| RAG
    RAG -->|"embed query + memory questions"| OL1
    RAG -->|"cosine distance scan"| DB3
    RAG -->|"read Q+A history"| DB4
    RAG -->|"read memory vectors"| DB5
    RAG -->|"streaming token generation"| OL2
    RAG -->|"save Q+A + embedding"| DB4
    RAG -->|"save memory vector"| DB5

    %% Summary read
    EP_SUM -->|"read file"| D2

    %% Responses back to UI
    RAG -->|"NDJSON: sources then tokens then done"| UI_CHAT
    EP_LIST -->|"document list JSON"| UI_DOCS
    EP_SUM -->|"Markdown content"| UI_MOD

    %% Cross-cutting wiring
    CFG -.->|"settings"| FASTAPI
    CFG -.->|"settings"| INGEST
    CFG -.->|"settings"| RAG
    DBI -.->|"init + connect"| PG
    LOG -.->|"log output"| D3
